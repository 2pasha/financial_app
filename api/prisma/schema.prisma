// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id              String          @id @default(uuid())
  clerkId         String          @unique
  email           String          @unique
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  monobankToken   MonobankToken?
  accounts        Account[]
  transactions    Transaction[]
  categories      Category[]
  incomes         Income[]
  budgetPlans     BudgetPlan[]
}

model Income {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  source    String
  amount    Float
  year      Int
  month     Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Category {
  id              String           @id @default(uuid())
  userId          String
  user            User             @relation(fields: [userId], references: [id])
  name            String
  icon            String
  color           String
  budget          Float
  mccCodes              Int[]            @default([])
  year                  Int?
  month                 Int?
  excludeFromDashboard  Boolean          @default(false)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  transactions    Transaction[]
  budgetPlanItems BudgetPlanItem[]
}

model BudgetPlan {
  id        String           @id @default(uuid())
  userId    String
  user      User             @relation(fields: [userId], references: [id])
  year      Int
  month     Int
  items     BudgetPlanItem[]
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  @@unique([userId, year, month])
}

model BudgetPlanItem {
  id         String     @id @default(uuid())
  planId     String
  plan       BudgetPlan @relation(fields: [planId], references: [id], onDelete: Cascade)
  categoryId String
  category   Category   @relation(fields: [categoryId], references: [id])
  budget     Float
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt

  @@unique([planId, categoryId])
}

model MonobankToken {
  id        String   @id @default(uuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id])
  token     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Account {
  id           String        @id @default(uuid())
  userId       String
  user         User          @relation(fields: [userId], references: [id])
  accountId    String        // Monobank account ID
  balance      BigInt
  currency     Int
  type         String
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  transactions Transaction[]
  
  @@unique([userId, accountId])
}

model Transaction {
  id             String    @id @default(uuid())
  userId         String
  user           User      @relation(fields: [userId], references: [id])
  accountId      String
  account        Account   @relation(fields: [accountId], references: [id])
  monobankId     String    @unique
  time           DateTime
  description    String
  amount         BigInt
  balance        BigInt
  currency       Int
  mcc            Int?
  originalMcc    Int?
  hold           Boolean
  commissionRate BigInt?
  cashbackAmount BigInt?
  categoryId     String?
  category       Category? @relation(fields: [categoryId], references: [id])
  createdAt      DateTime  @default(now())

  @@index([userId, time])
}
